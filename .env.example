# Firebase web app config — copy this file to .env and fill in the real values
# from Firebase console -> Project settings -> Your apps -> Web app -> SDK config.
# All keys must be prefixed with VITE_ so Vite exposes them to the client.
# These same values must also be set in the Vercel project's Environment Variables.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Blog (Clerk + shared Express API — see blog-plan.md) ---
# Clerk publishable key — safe to expose client-side. Clerk dashboard -> Developers -> API keys.
VITE_CLERK_PUBLISHABLE_KEY=

# Base URL of the shared Express API (server/), including the /api prefix.
# e.g. https://<your-render-service>.onrender.com/api or http://localhost:3000/api
VITE_API_URL=

# ImageKit — public-safe values only (same account as server/'s IK_* vars,
# minus the private key, which never leaves the backend).
VITE_IK_URL_ENDPOINT=
VITE_IK_PUBLIC_KEY=
