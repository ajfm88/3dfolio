# --- Server ---
PORT=3000
NODE_ENV=production

# Comma-separated allowed origins: the SPA in dev + your Vercel domain in prod.
# e.g. CLIENT_URL=http://localhost:5173,https://ajfm88.com
CLIENT_URL=http://localhost:5173

# --- MongoDB Atlas ---
MONGO_URI=

# --- Clerk (shared auth for /blog + /chat) ---
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# --- ImageKit (media; wired in later slices) ---
IK_URL_ENDPOINT=
IK_PUBLIC_KEY=
IK_PRIVATE_KEY=
